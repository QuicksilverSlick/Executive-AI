---
/**
 * BookingModal — fully custom, on-brand booking flow for Executive AI Training.
 *
 * Service selector → month-calendar + time-column picker (Calendly/Cal.com pattern)
 * → lead form → (paid: Stripe payment via GHL invoice) → confirmation. Writes the
 * contact + appointment directly to GHL via /api/booking/* (no GHL iframe).
 *
 * Triggers: `.calendly-trigger`, `.book-session`, `[data-booking]`. Deep-link a service
 * with `data-booking-service="discovery|assessment|consulting|tech|automation"`.
 */
const services = [
  { key: 'discovery',  name: 'Discovery Call',                 duration: '15 min', price: 'Free',
    blurb: 'A quick call to pinpoint where you are with AI — learning, exploring, or ready to implement — and point you the right way.' },
  { key: 'assessment', name: 'AI Readiness Assessment',        duration: '30 min', price: '$997',
    blurb: 'A comprehensive Q&A that produces your custom AI implementation roadmap and cost analysis.' },
  { key: 'consulting', name: 'Consulting Session',             duration: '60 min', price: '$297', priceNote: 'reg. $497',
    blurb: 'One-on-one strategic consulting on your AI initiatives, priorities, and rollout.' },
  { key: 'tech',       name: 'Technical Support',              duration: '60 min', price: '$197',
    blurb: 'Hands-on technical help implementing and troubleshooting your AI tools.' },
  { key: 'automation', name: 'Business Automation Consulting', duration: '60 min', price: '$497',
    blurb: 'Design and automate your business workflows end-to-end with AI.' },
];
---

<div id="booking-modal" class="bk-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Book a session">
  <div class="bk-panel">
    <button class="bk-close" aria-label="Close">&times;</button>

    <!-- Step 1: service selector -->
    <div class="bk-view" data-view="select">
      <header class="bk-head">
        <h2>Book Your Session</h2>
        <p>Choose the conversation that fits where you are with AI.</p>
      </header>
      <div class="bk-grid">
        {services.map((s) => (
          <button class="bk-card" data-service={s.key} data-name={s.name} data-price={s.price} data-duration={s.duration}>
            <div class="bk-card-top">
              <span class="bk-name">{s.name}</span>
              <span class={`bk-price ${s.price === 'Free' ? 'is-free' : ''}`}>{s.price}</span>
            </div>
            <span class="bk-dur">{s.duration}{s.priceNote ? ` · ${s.priceNote}` : ''}</span>
            <p class="bk-blurb">{s.blurb}</p>
            <span class="bk-go">Select →</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Step 2: calendar + time + form -->
    <div class="bk-view" data-view="book" hidden>
      <div class="bk-book-head">
        <button class="bk-back" aria-label="Back to services">← All sessions</button>
        <span class="bk-book-title"></span>
        <span class="bk-book-price"></span>
      </div>

      <div class="bk-book-body">
        <div class="bk-step" data-step="when">
          <div class="bk-when">
            <!-- Month calendar -->
            <div class="bk-cal">
              <div class="bk-cal-head">
                <button type="button" class="bk-cal-nav" data-nav="-1" aria-label="Previous month">‹</button>
                <span class="bk-cal-month"></span>
                <button type="button" class="bk-cal-nav" data-nav="1" aria-label="Next month">›</button>
              </div>
              <div class="bk-cal-dow"><span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span></div>
              <div class="bk-cal-grid"></div>
            </div>
            <!-- Time column -->
            <div class="bk-times">
              <div class="bk-times-head"><span class="bk-times-date">Select a date</span><small>Central Time</small></div>
              <div class="bk-slots"><p class="bk-hint">Pick a day to see available times.</p></div>
            </div>
          </div>
        </div>

        <form class="bk-step bk-form" data-step="who" hidden>
          <div class="bk-chosen"></div>
          <div class="bk-row2">
            <div><label class="bk-label">First name*</label><input name="firstName" required autocomplete="given-name" /></div>
            <div><label class="bk-label">Last name</label><input name="lastName" autocomplete="family-name" /></div>
          </div>
          <div class="bk-row2">
            <div><label class="bk-label">Email*</label><input name="email" type="email" required autocomplete="email" /></div>
            <div><label class="bk-label">Phone*</label><input name="phone" type="tel" required autocomplete="tel" /></div>
          </div>
          <label class="bk-label">Company</label>
          <input name="company" autocomplete="organization" />
          <label class="bk-label">Where are you with AI?</label>
          <select name="aiMaturity">
            <option value="">Select one…</option>
            <option value="Learning">Learning about AI</option>
            <option value="Exploring">Exploring if / how AI fits my business</option>
            <option value="Implementing">Ready to implement AI</option>
          </select>
          <label class="bk-label">What do you want to achieve? <span class="bk-opt">(optional)</span></label>
          <textarea name="goal" rows="2"></textarea>
          <input type="text" name="hp" class="bk-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <p class="bk-err" hidden></p>
          <button type="submit" class="bk-submit">Confirm Booking</button>
          <p class="bk-pay-note" hidden></p>
        </form>

        <div class="bk-step bk-redirect" data-step="redirect" hidden>
          <div class="bk-spin"></div>
          <h3>Booked — taking you to secure payment…</h3>
          <p class="bk-done-sub">If you're not redirected, <a class="bk-pay-link" href="#" target="_blank" rel="noopener">click here to pay</a>.</p>
        </div>

        <div class="bk-step bk-done" data-step="done" hidden>
          <div class="bk-check">✓</div>
          <h3>You're booked!</h3>
          <p class="bk-done-detail"></p>
          <p class="bk-done-sub">A confirmation is on its way. We look forward to speaking with you.</p>
          <button class="bk-done-close">Done</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .bk-overlay { position: fixed; inset: 0; z-index: 9999; display: none; align-items: center; justify-content: center; padding: 1rem; background: rgba(6,6,10,.78); backdrop-filter: blur(4px); }
  .bk-overlay.is-open { display: flex; }
  #booking-modal [hidden] { display: none !important; }
  .bk-panel { position: relative; width: 100%; max-width: 940px; max-height: 92vh; overflow: hidden; display: flex; flex-direction: column; background: #12121a; color: #f4f4f6; border: 1px solid #2a2a38; border-radius: 18px; box-shadow: 0 30px 80px rgba(0,0,0,.6); font-family: Inter, system-ui, sans-serif; }
  .bk-close { position: absolute; top: 12px; right: 16px; z-index: 3; background: none; border: none; color: #a0a0ad; font-size: 30px; line-height: 1; cursor: pointer; }
  .bk-close:hover { color: #f4f4f6; }
  .bk-view { overflow-y: auto; }
  .bk-head { padding: 34px 34px 8px; }
  .bk-head h2 { margin: 0 0 6px; font-size: 1.7rem; font-weight: 800; background: linear-gradient(90deg,#f4f4f6,#e8c47a); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .bk-head p { margin: 0; color: #a0a0ad; font-size: .98rem; }
  .bk-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14px; padding: 22px 34px 34px; }
  .bk-card { text-align: left; cursor: pointer; padding: 18px; border-radius: 14px; background: #1b1b26; border: 1px solid #2a2a38; color: inherit; transition: border-color .15s, transform .15s, background .15s; }
  .bk-card:hover { border-color: #d4a24e; transform: translateY(-2px); background: #20202d; }
  .bk-card-top { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .bk-name { font-weight: 700; font-size: 1.05rem; }
  .bk-price { font-weight: 800; color: #d4a24e; white-space: nowrap; }
  .bk-price.is-free { color: #37ca8b; }
  .bk-dur { display: block; margin-top: 2px; font-size: .8rem; color: #8a8a97; text-transform: uppercase; letter-spacing: .04em; }
  .bk-blurb { margin: 10px 0 12px; font-size: .9rem; color: #c3c3cf; line-height: 1.45; }
  .bk-go { font-size: .85rem; font-weight: 600; color: #d4a24e; }

  .bk-book-head { display: flex; align-items: center; gap: 14px; padding: 18px 30px; border-bottom: 1px solid #2a2a38; }
  .bk-back { background: none; border: 1px solid #2a2a38; color: #c3c3cf; padding: 7px 12px; border-radius: 9px; cursor: pointer; font-size: .85rem; white-space: nowrap; }
  .bk-back:hover { border-color: #d4a24e; color: #f4f4f6; }
  .bk-book-title { font-weight: 700; flex: 1; }
  .bk-book-price { font-weight: 800; color: #d4a24e; }
  .bk-book-body { padding: 22px 30px 30px; }

  /* Calendar + times (two-panel, Calendly/Cal.com pattern) */
  .bk-when { display: grid; grid-template-columns: 1fr 260px; gap: 26px; }
  .bk-cal-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .bk-cal-month { font-weight: 700; font-size: 1.02rem; }
  .bk-cal-nav { width: 34px; height: 34px; border-radius: 9px; background: #1b1b26; border: 1px solid #2a2a38; color: #e6e6ee; cursor: pointer; font-size: 1.1rem; line-height: 1; }
  .bk-cal-nav:hover:not(:disabled) { border-color: #d4a24e; }
  .bk-cal-nav:disabled { opacity: .3; cursor: default; }
  .bk-cal-dow { display: grid; grid-template-columns: repeat(7,1fr); gap: 4px; margin-bottom: 6px; }
  .bk-cal-dow span { text-align: center; font-size: .72rem; color: #8a8a97; text-transform: uppercase; letter-spacing: .04em; }
  .bk-cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 4px; }
  .bk-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: none; background: none; color: #e6e6ee; font-size: .9rem; cursor: pointer; }
  .bk-day.is-empty { visibility: hidden; }
  .bk-day.is-disabled { color: #40404c; cursor: default; }
  .bk-day.is-avail { background: rgba(212,162,78,.12); color: #f0d9ac; font-weight: 600; }
  .bk-day.is-avail:hover { background: rgba(212,162,78,.28); }
  .bk-day.is-sel { background: #d4a24e !important; color: #16110a !important; font-weight: 800; }

  .bk-times { display: flex; flex-direction: column; min-height: 0; }
  .bk-times-head { display: flex; flex-direction: column; margin-bottom: 10px; }
  .bk-times-date { font-weight: 700; font-size: .95rem; }
  .bk-times-head small { color: #8a8a97; font-size: .78rem; }
  .bk-slots { display: flex; flex-direction: column; gap: 8px; overflow-y: auto; max-height: 320px; padding-right: 4px; }
  .bk-slot { padding: 11px; border-radius: 10px; background: #1b1b26; border: 1px solid #2a2a38; color: #e6e6ee; cursor: pointer; font-size: .9rem; text-align: center; font-weight: 600; }
  .bk-slot:hover { border-color: #d4a24e; }
  .bk-slot.is-sel { background: #d4a24e; border-color: #d4a24e; color: #16110a; }
  .bk-hint { color: #8a8a97; font-size: .88rem; margin: 6px 0; }

  .bk-form input, .bk-form select, .bk-form textarea { width: 100%; box-sizing: border-box; padding: 10px 12px; border-radius: 10px; background: #14141d; border: 1px solid #2a2a38; color: #f4f4f6; font-size: .92rem; font-family: inherit; }
  .bk-form input:focus, .bk-form select:focus, .bk-form textarea:focus { outline: none; border-color: #d4a24e; }
  .bk-label { display: block; font-size: .82rem; font-weight: 600; color: #c3c3cf; margin: 16px 0 8px; }
  .bk-opt { color: #8a8a97; font-weight: 400; }
  .bk-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .bk-chosen { padding: 11px 14px; border-radius: 11px; background: rgba(212,162,78,.1); border: 1px solid rgba(212,162,78,.35); color: #e8c47a; font-weight: 600; font-size: .92rem; margin-bottom: 4px; }
  .bk-hp { position: absolute !important; left: -9999px !important; width: 1px !important; height: 1px !important; }
  .bk-err { color: #ff8a8a; font-size: .85rem; margin: 12px 0 0; }
  .bk-submit { width: 100%; margin-top: 18px; padding: 13px; border: none; border-radius: 11px; background: linear-gradient(90deg,#d4a24e,#e8c47a); color: #16110a; font-weight: 800; font-size: 1rem; cursor: pointer; }
  .bk-submit:hover { filter: brightness(1.05); }
  .bk-submit:disabled { opacity: .6; cursor: default; }
  .bk-pay-note { margin: 12px 0 0; font-size: .82rem; color: #8a8a97; text-align: center; }

  .bk-redirect, .bk-done { text-align: center; padding: 40px 10px; }
  .bk-spin { width: 42px; height: 42px; margin: 0 auto 18px; border: 3px solid #2a2a38; border-top-color: #d4a24e; border-radius: 50%; animation: bk-spin 0.8s linear infinite; }
  @keyframes bk-spin { to { transform: rotate(360deg); } }
  .bk-check { width: 62px; height: 62px; margin: 0 auto 16px; border-radius: 50%; background: rgba(55,202,139,.15); color: #37ca8b; font-size: 34px; display: flex; align-items: center; justify-content: center; }
  .bk-done h3, .bk-redirect h3 { margin: 0 0 8px; font-size: 1.4rem; }
  .bk-done-detail { color: #e8c47a; font-weight: 600; margin: 0 0 6px; }
  .bk-done-sub { color: #a0a0ad; font-size: .92rem; margin: 0 0 20px; }
  .bk-pay-link { color: #d4a24e; }
  .bk-done-close { padding: 11px 26px; border: 1px solid #2a2a38; border-radius: 11px; background: #1b1b26; color: #f4f4f6; cursor: pointer; }

  @media (max-width: 720px) { .bk-when { grid-template-columns: 1fr; } .bk-slots { max-height: 220px; } }
  @media (max-width: 640px) { .bk-grid { grid-template-columns: 1fr; padding: 18px; } .bk-head { padding: 26px 20px 4px; } .bk-book-head, .bk-book-body { padding-left: 18px; padding-right: 18px; } .bk-row2 { grid-template-columns: 1fr; } }
</style>

<script>
  (() => {
    const modal = document.getElementById('booking-modal');
    if (!modal) return;
    const $ = (s: string) => modal.querySelector(s) as HTMLElement;
    const viewSelect = $('[data-view="select"]');
    const viewBook = $('[data-view="book"]');
    const stepWhen = $('[data-step="when"]');
    const formEl = $('[data-step="who"]') as HTMLFormElement;
    const stepRedirect = $('[data-step="redirect"]');
    const stepDone = $('[data-step="done"]');
    const calGrid = $('.bk-cal-grid');
    const calMonth = $('.bk-cal-month');
    const slotsEl = $('.bk-slots');
    const timesDate = $('.bk-times-date');
    const titleEl = $('.bk-book-title');
    const priceEl = $('.bk-book-price');
    const chosenEl = $('.bk-chosen');
    const errEl = $('.bk-err') as HTMLElement;
    const payNote = $('.bk-pay-note') as HTMLElement;
    const submitBtn = $('.bk-submit') as HTMLButtonElement;

    const SERVICES: Record<string, { name: string; price: string; paid: boolean }> = {
      discovery: { name: 'Discovery Call', price: 'Free', paid: false },
      assessment: { name: 'AI Readiness Assessment', price: '$997', paid: true },
      consulting: { name: 'Consulting Session', price: '$297', paid: true },
      tech: { name: 'Technical Support', price: '$197', paid: true },
      automation: { name: 'Business Automation Consulting', price: '$497', paid: true },
    };
    const WINDOW_DAYS = 21;
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

    let current = { service: '', date: '', iso: '', label: '', dateLabel: '' };
    let viewY = 0, viewM = 0;
    let lastFocus: HTMLElement | null = null;

    const show = (el: HTMLElement, on: boolean) => { el.hidden = !on; };
    const ymd = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    const startOfDay = (d: Date) => { const x = new Date(d); x.setHours(0, 0, 0, 0); return x; };

    const openModal = () => { lastFocus = document.activeElement as HTMLElement; modal.classList.add('is-open'); modal.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; };
    function closeModal() {
      modal.classList.remove('is-open'); modal.setAttribute('aria-hidden', 'true'); document.body.style.overflow = '';
      show(viewBook, false); show(viewSelect, true); resetBook();
      if (lastFocus?.focus) lastFocus.focus();
    }
    function resetBook() {
      show(stepWhen, true); show(formEl, false); show(stepRedirect, false); show(stepDone, false);
      formEl.reset(); errEl.hidden = true;
      slotsEl.innerHTML = '<p class="bk-hint">Pick a day to see available times.</p>';
      timesDate.textContent = 'Select a date';
      current = { service: '', date: '', iso: '', label: '', dateLabel: '' };
    }

    function dayState(d: Date) {
      const today = startOfDay(new Date());
      const max = new Date(today); max.setDate(max.getDate() + WINDOW_DAYS);
      const day = d.getDay();
      if (d < today || d > max) return 'disabled';
      if (day === 0 || day === 6) return 'disabled';
      return 'avail';
    }

    function renderCalendar() {
      calMonth.textContent = `${MONTHS[viewM]} ${viewY}`;
      calGrid.innerHTML = '';
      const first = new Date(viewY, viewM, 1);
      const startPad = first.getDay();
      const daysInMonth = new Date(viewY, viewM + 1, 0).getDate();
      for (let i = 0; i < startPad; i++) { const s = document.createElement('span'); s.className = 'bk-day is-empty'; calGrid.appendChild(s); }
      for (let dnum = 1; dnum <= daysInMonth; dnum++) {
        const d = new Date(viewY, viewM, dnum);
        const state = dayState(d);
        const b = document.createElement('button');
        b.type = 'button'; b.className = `bk-day is-${state}`; b.textContent = String(dnum);
        if (state === 'avail') {
          const ds = ymd(d);
          if (ds === current.date) b.classList.add('is-sel');
          b.addEventListener('click', () => selectDate(d, b));
        } else { b.disabled = true; }
        calGrid.appendChild(b);
      }
      // nav bounds
      const today = startOfDay(new Date());
      const maxD = new Date(today); maxD.setDate(maxD.getDate() + WINDOW_DAYS);
      (modal.querySelector('[data-nav="-1"]') as HTMLButtonElement).disabled = (viewY === today.getFullYear() && viewM === today.getMonth());
      (modal.querySelector('[data-nav="1"]') as HTMLButtonElement).disabled = (viewY === maxD.getFullYear() && viewM === maxD.getMonth());
    }

    async function selectDate(d: Date, cell: HTMLElement) {
      current.date = ymd(d);
      current.dateLabel = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
      current.iso = '';
      calGrid.querySelectorAll('.bk-day').forEach((c) => c.classList.remove('is-sel'));
      cell.classList.add('is-sel');
      timesDate.textContent = current.dateLabel;
      show(formEl, false);
      slotsEl.innerHTML = '<p class="bk-hint">Loading times…</p>';
      try {
        const r = await fetch(`/api/booking/slots?service=${current.service}&date=${current.date}`);
        const j = await r.json();
        if (!j.success || !j.slots.length) { slotsEl.innerHTML = '<p class="bk-hint">No times available — try another day.</p>'; return; }
        slotsEl.innerHTML = '';
        j.slots.forEach((s: any) => {
          const b = document.createElement('button');
          b.type = 'button'; b.className = 'bk-slot'; b.textContent = s.label;
          b.addEventListener('click', () => {
            slotsEl.querySelectorAll('.bk-slot').forEach((x) => x.classList.remove('is-sel'));
            b.classList.add('is-sel');
            current.iso = s.iso; current.label = s.label;
            chosenEl.textContent = `${current.dateLabel} at ${s.label} (CT)`;
            show(formEl, true);
            formEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
          slotsEl.appendChild(b);
        });
      } catch { slotsEl.innerHTML = '<p class="bk-hint">Could not load times. Please try again.</p>'; }
    }

    function firstAvailable(): Date {
      const d = startOfDay(new Date());
      for (let i = 0; i < WINDOW_DAYS + 2; i++) { d.setDate(d.getDate() + 1); if (dayState(d) === 'avail') return new Date(d); }
      return new Date();
    }

    function openService(key: string) {
      const svc = SERVICES[key]; if (!svc) return;
      current.service = key;
      titleEl.textContent = svc.name;
      priceEl.textContent = svc.paid ? svc.price : '';
      payNote.hidden = !svc.paid;
      payNote.textContent = svc.paid ? `${svc.price} — you'll be taken to secure Stripe checkout to confirm your ${svc.name.toLowerCase()}.` : '';
      show(viewSelect, false); show(viewBook, true);
      show(stepWhen, true); show(formEl, false); show(stepRedirect, false); show(stepDone, false);
      const fa = firstAvailable();
      viewY = fa.getFullYear(); viewM = fa.getMonth();
      current.date = '';
      renderCalendar();
      // auto-select first available date
      const cell = [...calGrid.querySelectorAll('.bk-day.is-avail')].find((c) => Number(c.textContent) === fa.getDate()) as HTMLElement;
      if (cell) selectDate(fa, cell);
      if (window.gtag) window.gtag('event', 'begin_checkout', { items: [{ item_name: svc.name }] });
    }

    modal.querySelectorAll('[data-nav]').forEach((btn) => btn.addEventListener('click', () => {
      const delta = Number((btn as HTMLElement).dataset.nav);
      const nd = new Date(viewY, viewM + delta, 1);
      viewY = nd.getFullYear(); viewM = nd.getMonth();
      renderCalendar();
    }));

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault(); errEl.hidden = true;
      if (!current.iso) { errEl.textContent = 'Please pick a time.'; errEl.hidden = false; return; }
      const fd = new FormData(formEl);
      submitBtn.disabled = true; submitBtn.textContent = 'Booking…';
      try {
        const r = await fetch('/api/booking/create', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service: current.service, iso: current.iso,
            firstName: fd.get('firstName'), lastName: fd.get('lastName'), email: fd.get('email'),
            phone: fd.get('phone'), company: fd.get('company'), aiMaturity: fd.get('aiMaturity'),
            goal: fd.get('goal'), hp: fd.get('hp'),
          }),
        });
        const j = await r.json();
        if (!j.success) throw new Error(j.error || 'Booking failed');
        if (window.gtag) window.gtag('event', 'generate_lead', { event_category: 'booking', event_label: SERVICES[current.service].name });
        if (j.paymentUrl) {
          (modal.querySelector('.bk-pay-link') as HTMLAnchorElement).href = j.paymentUrl;
          show(stepWhen, false); show(formEl, false); show(stepRedirect, true);
          window.location.href = j.paymentUrl;
        } else {
          ($('.bk-done-detail') as HTMLElement).textContent = `${SERVICES[current.service].name} — ${current.dateLabel} at ${current.label} (CT)`;
          show(stepWhen, false); show(formEl, false); show(stepDone, true);
        }
      } catch (err) {
        errEl.textContent = (err as Error).message || 'Something went wrong. Please try again.';
        errEl.hidden = false;
      } finally { submitBtn.disabled = false; submitBtn.textContent = 'Confirm Booking'; }
    });

    modal.querySelectorAll('.bk-card').forEach((c) => c.addEventListener('click', () => openService((c as HTMLElement).dataset.service!)));
    $('.bk-back').addEventListener('click', () => { show(viewBook, false); show(viewSelect, true); resetBook(); });
    $('.bk-close').addEventListener('click', closeModal);
    $('.bk-done-close').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal(); });

    const KEYS = ['discovery', 'assessment', 'consulting', 'tech', 'automation'];
    function bindTriggers() {
      document.querySelectorAll('.calendly-trigger, .book-session, [data-booking]').forEach((el) => {
        const e = el as HTMLElement;
        if (e.dataset.bkBound) return; e.dataset.bkBound = '1';
        e.addEventListener('click', (ev) => {
          ev.preventDefault(); openModal();
          const key = e.getAttribute('data-booking-service');
          if (key && KEYS.includes(key)) openService(key);
          else { show(viewBook, false); show(viewSelect, true); }
          if (window.gtag) window.gtag('event', 'cta_click', { cta_name: 'Book a Session', cta_location: (e.closest('section')?.id || 'page') });
        });
      });
    }
    bindTriggers();
    new MutationObserver(bindTriggers).observe(document.body, { childList: true, subtree: true });
  })();
</script>
